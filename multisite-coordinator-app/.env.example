# Network Configuration
NETWORK=mumbai  # or 'polygon' for mainnet
TOKEN_ADDRESS=0xYourTokenAddress
LP_ADDRESS=0xYourLPAddress

# Launch Parameters
LAUNCH_TIME=2024-12-01T09:00:00Z
INITIAL_LIQUIDITY=2000
TOTAL_BUY_AMOUNT=500

# Wallet Configuration
NUM_WALLETS=5

# Privacy Settings (0-1 range)
TIMING_VARIANCE=0.5  # Higher = more spread out
AMOUNT_VARIANCE=0.5  # Higher = more variation

# Test Mode
TEST_MODE=true
ITERATIONS=10

# VPN Configuration
VPN_ENABLED=false
VPN_PROVIDER=none  # 'nordvpn', 'expressvpn', 'mullvad', etc.
